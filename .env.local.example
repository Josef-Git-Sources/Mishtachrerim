# ================================================================
# Mishtachrerim — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ================================================================

# ----------------------------------------------------------------
# Supabase (required — client + server)
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------------
# Supabase Service Role (server only — never expose to browser)
# Required for admin operations in Phase 2+
# ----------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------
# Site URL (required — used for canonical tags, sitemaps, OG tags)
# Staging:    https://hatzaad.intelgrp.com
# Production: https://hatzaad-haba.co.il
# ----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
